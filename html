<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Top‑Down Circle with Joystick</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background: #2b2b2b;
            touch-action: none; /* prevent browser gestures */
            font-family: sans-serif;
        }
        canvas {
            display: block;
            background: #3a5a40;
        }
        /* Joystick base (visible circle) */
        .joystick-base {
            position: fixed;
            bottom: 40px;
            left: 40px;
            width: 120px;
            height: 120px;
            background: rgba(255, 255, 255, 0.15);
            border: 3px solid rgba(255, 255, 255, 0.6);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            pointer-events: auto;
            z-index: 10;
        }
        /* Joystick thumb (movable handle) */
        .joystick-thumb {
            position: fixed;
            bottom: 40px;
            left: 40px;
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none; /* events go to base */
            z-index: 11;
            box-shadow: 0 0 8px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>
    <canvas id="gameCanvas"></canvas>
    <div class="joystick-base" id="joystickBase"></div>
    <div class="joystick-thumb" id="joystickThumb"></div>

    <script>
        (function() {
            const canvas = document.getElementById('gameCanvas');
            const ctx = canvas.getContext('2d');

            // --- Canvas resize ---
            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            // --- Game character ---
            const player = {
                x: canvas.width / 2,
                y: canvas.height / 2,
                radius: 20,
                speed: 200  // pixels per second
            };

            // --- Joystick setup ---
            const baseEl = document.getElementById('joystickBase');
            const thumbEl = document.getElementById('joystickThumb');

            let activePointerId = null;
            let baseCenter = { x: 0, y: 0 };
            let maxDist = 0;    // max distance from base center to edge (thumb can't exceed this)
            let joystickVec = { x: 0, y: 0 };  // normalised direction * magnitude (0..1)

            function updateBaseDimensions() {
                const rect = baseEl.getBoundingClientRect();
                baseCenter.x = rect.left + rect.width / 2;
                baseCenter.y = rect.top + rect.height / 2;
                // The thumb can move within the base radius minus its own half-size
                maxDist = (rect.width / 2) - (thumbEl.offsetWidth / 2);
                // Ensure minimum 0
                if (maxDist < 0) maxDist = 0;
            }
            window.addEventListener('resize', updateBaseDimensions);
            updateBaseDimensions();

            // Move thumb to a screen position (clamped to base circle)
            function moveThumb(clientX, clientY) {
                let dx = clientX - baseCenter.x;
                let dy = clientY - baseCenter.y;
                let dist = Math.sqrt(dx * dx + dy * dy);

                if (dist > maxDist) {
                    dx = (dx / dist) * maxDist;
                    dy = (dy / dist) * maxDist;
                    dist = maxDist;
                }

                // Update thumb position (relative to viewport)
                thumbEl.style.left = (baseCenter.x + dx) + 'px';
                thumbEl.style.top = (baseCenter.y + dy) + 'px';
                // No transform needed – already centered via CSS transform? 
                // We set left/top to the thumb's center point. CSS already translates -50% -50%.
                // So we just set left/top = center position.

                // Update joystick vector (normalised direction * strength)
                if (dist > 1) {
                    joystickVec.x = dx / maxDist;   // -1 to 1
                    joystickVec.y = dy / maxDist;
                } else {
                    joystickVec.x = 0;
                    joystickVec.y = 0;
                }
            }

            function resetThumb() {
                thumbEl.style.left = baseCenter.x + 'px';
                thumbEl.style.top = baseCenter.y + 'px';
                joystickVec.x = 0;
                joystickVec.y = 0;
                activePointerId = null;
            }

            // --- Pointer events (mouse + touch) ---
            function onPointerDown(e) {
                if (e.target === baseEl && activePointerId === null) {
                    e.preventDefault();
                    activePointerId = e.pointerId;
                    baseEl.setPointerCapture(e.pointerId);
                    updateBaseDimensions(); // just in case
                    moveThumb(e.clientX, e.clientY);
                }
            }

            function onPointerMove(e) {
                if (activePointerId === e.pointerId) {
                    e.preventDefault();
                    moveThumb(e.clientX, e.clientY);
                }
            }

            function onPointerUp(e) {
                if (activePointerId === e.pointerId) {
                    e.preventDefault();
                    resetThumb();
                    baseEl.releasePointerCapture(e.pointerId);
                }
            }

            // Attach listeners to the base element
            baseEl.addEventListener('pointerdown', onPointerDown);
            baseEl.addEventListener('pointermove', onPointerMove);
            baseEl.addEventListener('pointerup', onPointerUp);
            baseEl.addEventListener('pointercancel', onPointerUp);
            // Also listen on window for move/up to catch events if pointer leaves base
            window.addEventListener('pointermove', (e) => {
                if (activePointerId === e.pointerId) {
                    moveThumb(e.clientX, e.clientY);
                }
            });
            window.addEventListener('pointerup', (e) => {
                if (activePointerId === e.pointerId) {
                    resetThumb();
                }
            });

            // --- Game loop ---
            let lastTime = performance.now();

            function gameLoop(now) {
                let dt = (now - lastTime) / 1000;
                if (dt > 0.1) dt = 0.1;  // cap to avoid jumps
                lastTime = now;

                // Update player position based on joystick vector
                if (joystickVec.x !== 0 || joystickVec.y !== 0) {
                    player.x += joystickVec.x * player.speed * dt;
                    player.y += joystickVec.y * player.speed * dt;

                    // Keep player inside canvas (with margin equal to radius)
                    const margin = player.radius;
                    if (player.x < margin) player.x = margin;
                    if (player.x > canvas.width - margin) player.x = canvas.width - margin;
                    if (player.y < margin) player.y = margin;
                    if (player.y > canvas.height - margin) player.y = canvas.height - margin;
                }

                // Draw everything
                drawBackground();
                drawPlayer();

                requestAnimationFrame(gameLoop);
            }

            function drawBackground() {
                // Clear canvas
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                // Draw a grid to give a feeling of a top-down plane
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
                ctx.lineWidth = 1;
                const gridSize = 50;
                for (let x = 0; x < canvas.width; x += gridSize) {
                    ctx.beginPath();
                    ctx.moveTo(x, 0);
                    ctx.lineTo(x, canvas.height);
                    ctx.stroke();
                }
                for (let y = 0; y < canvas.height; y += gridSize) {
                    ctx.beginPath();
                    ctx.moveTo(0, y);
                    ctx.lineTo(canvas.width, y);
                    ctx.stroke();
                }
            }

            function drawPlayer() {
                // Simple circle (top-down view)
                ctx.beginPath();
                ctx.arc(player.x, player.y, player.radius, 0, Math.PI * 2);
                ctx.fillStyle = '#F4A261';
                ctx.fill();
                ctx.strokeStyle = '#E76F51';
                ctx.lineWidth = 3;
                ctx.stroke();

                // Small "eyes" to indicate facing direction? Not needed for top-down.
                // Optionally add a subtle shadow
                ctx.shadowColor = 'rgba(0,0,0,0.3)';
                ctx.shadowBlur = 8;
                ctx.fill();
                ctx.shadowColor = 'transparent';
                ctx.shadowBlur = 0;
            }

            // Start the loop
            requestAnimationFrame(gameLoop);
        })();
    </script>
</body>
</html>
